{
  "mcpServers": {
    "linear": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "linear-mcp-server"]
    },
    "playwright": {
      "type": "stdio",
      "command": "/opt/homebrew/bin/node",
      "args": [
        "/opt/homebrew/lib/node_modules/@playwright/mcp/cli.js",
        "--browser", "chromium"
      ]
    }
  }
}
